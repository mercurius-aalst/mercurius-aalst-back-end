{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MercuriusDB": "Server=localhost;Port=5432;Username=postgres;Database=mercuriusdb"
  },
  "FileStorage": {
    "Location": "C:\\Development\\Personal\\images",
    "MaxFileSizeInMB": 5
  },
  "TeamInvite": {
    "ResendCooldownDays": 3,
    "ExpirationDays": 14,
    "RetentionDays": 90,
