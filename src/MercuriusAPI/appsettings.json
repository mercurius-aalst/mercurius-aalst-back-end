{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MercuriusDB": "Server=localhost;Port=5432;Username=postgres;Database=mercuriusdb"
  },
  "FileStorage": {
    "Location": "C:\\Development\\Personal\\images",
    "MaxFileSizeInMB": 5
  },
  "TeamInvite": {
    "ResendCooldownDays": 3
  },
  "Jwt": {
    "Issuer": "LAN.API",
    "Audience": "MercuriusLAN",
    "ExpiresInMinutes": 60
  },
  "ExternalAuth": {
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "",
      "MetadataAddress": "https://accounts.google.com/.well-known/openid-configuration",
      "Scopes": [ "openid", "email", "profile" ],
      "ValidIssuers": [ "https://accounts.google.com", "accounts.google.com" ],
      "AdditionalAuthorizationParameters": {
        "access_type": "offline",
        "prompt": "consent"
      }
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "",
      "MetadataAddress": "https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration",
      "Scopes": [ "openid", "email", "profile" ]
    }
  }
}
