    "GlobalPermitLimit": 120,
    "SearchPermitLimit": 30,
    "WindowSeconds": 60
  },
  "Auth0": {
    "Audience": "https://devapi.mercurius-aalst.be",
    "Authority": "https://mercurius-aalst.eu.auth0.com/",
    "RoleClaimType": "https://mercurius-aalst.be/roles",
    "ManagementAudience": "https://mercurius-aalst.eu.auth0.com/api/v2/",
    "DatabaseConnection": "Username-Password-Authentication"
